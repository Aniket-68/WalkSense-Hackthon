{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "GitHubActionsECRPush",
            "Effect": "Allow",
            "Action": [
                "ecr:GetAuthorizationToken"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ECRPushImages",
            "Effect": "Allow",
            "Action": [
                "ecr:BatchCheckLayerAvailability",
                "ecr:InitiateLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:CompleteLayerUpload",
                "ecr:PutImage",
                "ecr:GetDownloadUrlForLayer",
                "ecr:BatchGetImage"
            ],
            "Resource": [
                "arn:aws:ecr:us-east-1:ACCOUNT_ID:repository/walksense-backend",
                "arn:aws:ecr:us-east-1:ACCOUNT_ID:repository/walksense-frontend"
            ]
        },
        {
            "Sid": "ECSDeployment",
            "Effect": "Allow",
            "Action": [
                "ecs:DescribeServices",
                "ecs:UpdateService",
                "ecs:RegisterTaskDefinition",
                "ecs:DescribeTaskDefinition",
                "ecs:ListTaskDefinitions",
                "ecs:DescribeTasks",
                "ecs:ListTasks"
            ],
            "Resource": "*",
            "Condition": {
                "ArnLike": {
                    "ecs:cluster": "arn:aws:ecs:us-east-1:ACCOUNT_ID:cluster/walksense-cluster"
                }
            }
        },
        {
            "Sid": "PassExecutionRole",
            "Effect": "Allow",
            "Action": "iam:PassRole",
            "Resource": [
                "arn:aws:iam::ACCOUNT_ID:role/walksense-ecs-execution-role",
                "arn:aws:iam::ACCOUNT_ID:role/walksense-ecs-task-role"
            ]
        }
    ]
}