# WalkSense Frontend Environment Variables
# Copy this to .env and adjust for your deployment.

# Backend API URL (no trailing slash)
# Local dev:    http://localhost:8080
# EC2 prod:     https://api.walksense.example.com
VITE_API_URL=http://localhost:8080

# (Optional) Override WebSocket URL — auto-derived from API_URL if omitted
# VITE_WS_URL=wss://api.walksense.example.com/ws

# Camera source: "backend" (server-attached camera) or "browser" (user's webcam → WS)
# Use "browser" when deploying backend to EC2 (no physical camera on server)
VITE_CAMERA_MODE=browser
