[Unit]
Description=WalkSense Backend API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/WalkSense-Hackthon/Backend
EnvironmentFile=/home/ubuntu/WalkSense-Hackthon/Backend/.env
ExecStart=/home/ubuntu/WalkSense-Hackthon/Backend/deploy/ec2/start_backend.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
