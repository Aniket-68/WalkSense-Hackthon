# ============================================================================
# WalkSense Configuration - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual API keys and credentials
# This template file is safe to commit to version control
# ============================================================================

# OpenAI API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Together AI
TOGETHER_API_KEY=your-together-api-key-here

# Replicate API
REPLICATE_API_TOKEN=your-replicate-api-token-here

# HuggingFace Hub
HUGGINGFACE_TOKEN=hf_your-huggingface-token-here

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account-key.json

# Azure Speech Services
AZURE_SPEECH_API_KEY=your-azure-speech-api-key-here
AZURE_SPEECH_REGION=eastus

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
MODEL_CACHE_DIR=./models/cache
