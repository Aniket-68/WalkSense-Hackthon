# ============================================================================
# WalkSense Configuration - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual API keys and credentials
# This template file is safe to commit to version control
# ============================================================================

# OpenAI API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Deepgram API (STT)
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Together AI
TOGETHER_API_KEY=your-together-api-key-here

# Replicate API
REPLICATE_API_TOKEN=your-replicate-api-token-here

# HuggingFace Hub
HUGGINGFACE_TOKEN=hf_your-huggingface-token-here

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account-key.json

# Azure Speech Services
AZURE_SPEECH_API_KEY=your-azure-speech-api-key-here
AZURE_SPEECH_REGION=eastus

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
MODEL_CACHE_DIR=./models/cache

# CORS (required for cookie-based refresh token flow)
# Comma-separated frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173

# Auth bootstrap account (change before production)
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=ChangeMe_123!
AUTH_BOOTSTRAP_FORCE_RESET=false
# Keep disabled by default and provision users with:
#   python3 -m API.provision_user --username <user> --password '<pass>'
AUTH_BOOTSTRAP_ENABLED=false

# App environment
APP_ENV=development

# JWT secrets (must be strong random strings in production)
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Refresh cookie options
AUTH_REFRESH_COOKIE_NAME=walksense_refresh_token
AUTH_COOKIE_SECURE=false
# SameSite=None is enabled only when cross-site mode is required.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_CROSS_SITE=false

# Rate limiting / brute-force controls
AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_LOGIN_BLOCK_SECONDS=600
AUTH_RATE_LIMIT_REFRESH_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_REFRESH_BLOCK_SECONDS=600

# Auth retention cleanup / housekeeping
AUTH_HOUSEKEEPING_ENABLED=true
AUTH_CLEANUP_INTERVAL_SECONDS=3600
AUTH_AUDIT_RETENTION_SECONDS=2592000
AUTH_RATE_LIMIT_RETENTION_SECONDS=86400

# Lockout/compromise alerting + monitoring
AUTH_ALERT_WINDOW_SECONDS=300
AUTH_ALERT_COMPROMISE_THRESHOLD=5
AUTH_ALERT_COOLDOWN_SECONDS=300
AUTH_ALERT_CLOUDWATCH_ENABLED=false
AUTH_ALERT_CLOUDWATCH_NAMESPACE=WalkSense/Security
